# =============================================================================
# AI Provider Configuration
# =============================================================================

# Which AI provider to use: "claude", "chatgpt", "gemini", "grok"
AI_PROVIDER=claude

# Your API key for the selected provider
# - Claude:  get at https://console.anthropic.com/
# - ChatGPT: get at https://platform.openai.com/api-keys
# - Gemini:  get at https://aistudio.google.com/apikey
# - Grok:    get at https://console.x.ai/
AI_API_KEY=your-api-key-here

# Model override (leave empty to use the default for your provider)
# Defaults: claude=claude-sonnet-4-20250514, chatgpt=gpt-4.1, gemini=gemini-2.5-flash, grok=grok-3
AI_MODEL=

# =============================================================================
# Alpaca Broker Configuration
# =============================================================================

# Alpaca API Keys
# Get yours at: https://app.alpaca.markets/ (paper) or https://alpaca.markets/ (live)
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key

# Set to "true" for paper trading, "false" for live trading
# WARNING: Only set to "false" after extensive paper trading validation!
ALPACA_PAPER=true
